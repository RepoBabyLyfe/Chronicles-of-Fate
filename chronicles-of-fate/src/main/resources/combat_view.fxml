<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>
<StackPane fx:id="rootPane" stylesheets="@style.css" prefWidth="1000" prefHeight="750" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg.matricola.presentation.CombatController">

    <Canvas fx:id="spaceCanvas" mouseTransparent="true" StackPane.alignment="CENTER"/>

    <BorderPane fx:id="combatPane">
        <top>
            <VBox alignment="CENTER" spacing="10" styleClass="ps2-panel, top-arena-margin" BorderPane.alignment="CENTER">
                <Label text="Avatar dell'Entropia" styleClass="boss-name"/>
                <ProgressBar fx:id="enemyHpBar" progress="1.0" prefWidth="450" styleClass="hp-bar, hp-bar-enemy"/>
                <Label fx:id="enemyHpLabel" text="AURA Boss: 50/50" styleClass="boss-hp-text"/>
            </VBox>
        </top>

        <center>
            <HBox alignment="CENTER" spacing="30" BorderPane.alignment="CENTER">
                <Label fx:id="systemLogLabel" text="In attesa di comandi..." styleClass="ps2-panel, log-display"/>
                <TextArea fx:id="historyLogArea" editable="false" wrapText="true" prefWidth="350" prefHeight="130" styleClass="ps2-panel, history-log"/>
            </HBox>
        </center>

        <bottom>
            <VBox spacing="20" styleClass="ps2-panel, bottom-arena-margin" BorderPane.alignment="CENTER">
                <HBox alignment="CENTER" spacing="60">
                    <VBox alignment="CENTER" spacing="5">
                        <Label fx:id="playerHpLabel" text="AURA Eroe: 30/30" styleClass="player-hp-text"/>
                        <ProgressBar fx:id="playerHpBar" progress="1.0" prefWidth="280" styleClass="hp-bar"/>
                    </VBox>
                    <Label fx:id="playerFocusLabel" text="Focus: 5" styleClass="player-focus-text"/>
                </HBox>

                <HBox fx:id="handContainer" alignment="CENTER" spacing="15" minHeight="200"/>

                <HBox alignment="CENTER" spacing="30">
                    <Button text="&gt; PASSA TURNO &lt;" onAction="#onNextPhaseClicked" styleClass="ps2-button"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER">
                    <Button text="Riavvia Scontro" onAction="#onRestartClicked" styleClass="system-button"/>
                    <Button text="Salva Partita" onAction="#onSaveClicked" styleClass="system-button"/>
                    <Button text="Torna al Menù" onAction="#onBackToMenuClicked" styleClass="system-button"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>

    <VBox fx:id="diceOverlay" visible="false" alignment="CENTER" spacing="15" styleClass="dice-screen-overlay">
        <Label text="[ TIRA I DADI PER ATTACCARE ]" styleClass="dice-overlay-title"/>
        <Label fx:id="diceValueLabel" text="⚀" styleClass="dice-live-value"/>
    </VBox>
</StackPane>