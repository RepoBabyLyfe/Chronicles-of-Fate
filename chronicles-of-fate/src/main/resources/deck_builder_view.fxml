<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>

<StackPane fx:id="rootPane" stylesheets="@style.css" prefWidth="1200" prefHeight="800" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg.matricola.presentation.DeckBuilderController">
    <Canvas fx:id="spaceCanvas" mouseTransparent="true" StackPane.alignment="CENTER"/>

    <HBox spacing="10" styleClass="deck-builder-padding">

        <VBox alignment="TOP_CENTER" spacing="15" HBox.hgrow="ALWAYS" prefWidth="580">
            <Label text="CATALOGO CARTE" styleClass="title-text, deck-builder-title"/>
            <Label text="Clicca su una carta per aggiungerla al mazzo." styleClass="floating-log, deck-builder-hint"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" styleClass="clean-scroll-pane">
                <FlowPane fx:id="catalogContainer" hgap="25" vgap="25" alignment="TOP_CENTER"/>
            </ScrollPane>
        </VBox>

        <Separator orientation="VERTICAL" styleClass="deck-builder-separator"/>

        <VBox alignment="TOP_CENTER" spacing="15" HBox.hgrow="ALWAYS" prefWidth="580">
            <Label fx:id="deckCountLabel" text="IL TUO MAZZO (0/5)" styleClass="title-text, deck-count-label"/>
            <Label text="Clicca su una carta per rimuoverla." styleClass="floating-log, deck-builder-hint"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" styleClass="clean-scroll-pane">
                <FlowPane fx:id="deckContainer" hgap="25" vgap="25" alignment="TOP_CENTER"/>
            </ScrollPane>

            <VBox alignment="BOTTOM_CENTER" spacing="15" styleClass="deck-builder-bottom">
                <Label fx:id="focusLabel" text="Costo Medio Focus: 0.0" styleClass="player-focus-text"/>
                <HBox alignment="CENTER" spacing="20">
                    <Button text="&lt; INDIETRO" onAction="#onBackClicked" styleClass="system-button"/>
                    <Button fx:id="confirmButton" text="[ CONFERMA E COMBATTI ]" onAction="#onConfirmClicked" styleClass="ps2-button" disable="true"/>
                </HBox>
            </VBox>
        </VBox>

    </HBox>

    <!-- Zoom Overlay laterale (mouse-transparent, gestito da CardZoomOverlay) -->
    <StackPane fx:id="zoomOverlayPane" alignment="CENTER" mouseTransparent="true" StackPane.alignment="CENTER"/>

</StackPane>