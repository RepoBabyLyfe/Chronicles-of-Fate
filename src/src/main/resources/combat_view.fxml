<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane fx:id="rootPane" stylesheets="@style.css" prefWidth="1200" prefHeight="800" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg123283.presentation.CombatController">
    <Canvas fx:id="spaceCanvas" mouseTransparent="true" StackPane.alignment="CENTER"/>

    <BorderPane fx:id="combatPane">
        <top>
            <BorderPane styleClass="top-arena-margin" BorderPane.alignment="CENTER">

                <left>
                    <VBox alignment="TOP_LEFT" prefWidth="160">
                        <Button text="☰" onAction="#onPauseClicked" styleClass="hamburger-button"/>
                    </VBox>
                </left>

                <center>
                    <VBox alignment="CENTER" spacing="10" styleClass="ps2-panel" maxWidth="500">
                        <Label fx:id="enemyNameLabel" text="" styleClass="boss-name"/>
                        <ProgressBar fx:id="enemyHpBar" progress="1.0" prefWidth="450" styleClass="hp-bar, hp-bar-enemy"/>
                        <Label fx:id="enemyHpLabel" text="AURA Boss: 50/50" styleClass="boss-hp-text"/>
                    </VBox>
                </center>
                <right>
                    <Region prefWidth="160"/>
                </right>
            </BorderPane>
        </top>

        <center>
            <VBox alignment="CENTER" mouseTransparent="true">
                <Label fx:id="systemLogLabel" text="In attesa di comandi..." styleClass="floating-log"/>
            </VBox>
        </center>

        <bottom>
            <BorderPane styleClass="bottom-arena-margin" BorderPane.alignment="CENTER">

                <left>
                    <VBox alignment="BOTTOM_LEFT" prefWidth="240">
                        <TextArea fx:id="historyLogArea" editable="false" wrapText="true" prefWidth="240" prefHeight="140" styleClass="history-log"/>
                    </VBox>
                </left>

                <center>
                    <VBox alignment="BOTTOM_CENTER" spacing="25">
                        <HBox fx:id="handContainer" alignment="CENTER" spacing="15"/>
                        <Button text="&gt; PASSA TURNO &lt;" onAction="#onNextPhaseClicked" styleClass="ps2-button"/>
                    </VBox>
                </center>

                <right>
                    <VBox alignment="BOTTOM_RIGHT" spacing="15" BorderPane.alignment="BOTTOM_RIGHT" prefWidth="240" translateY="-20" translateX="-20">


                        <VBox alignment="CENTER" spacing="12" styleClass="ps2-panel, player-stats-panel" maxHeight="-Infinity" maxWidth="220">
                            <Label fx:id="playerFocusLabel" text="Focus: 10" styleClass="player-focus-text, combat-focus-text"/>

                            <VBox alignment="CENTER" spacing="6">
                                <Label fx:id="playerHpLabel" text="AURA Eroe: 30/30" styleClass="player-hp-text"/>
                                <ProgressBar fx:id="playerHpBar" progress="1.0" prefWidth="190" styleClass="hp-bar"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </right>

            </BorderPane>
        </bottom>
    </BorderPane>

    <VBox fx:id="diceOverlay" visible="false" alignment="CENTER" spacing="15" styleClass="dice-screen-overlay">
        <Label text="[ TIRA I DADI PER ATTACCARE ]" styleClass="dice-overlay-title"/>
        <Label fx:id="diceValueLabel" text="⚀" styleClass="dice-live-value"/>
    </VBox>

    <VBox fx:id="enemyCardOverlay" visible="false" alignment="CENTER" mouseTransparent="true" styleClass="enemy-overlay-bg">
        <StackPane styleClass="card-container, enemy-card-glow" scaleX="1.3" scaleY="1.3">
            <ImageView fx:id="enemyCardImage" fitWidth="280" fitHeight="400" preserveRatio="true" />
            <Label fx:id="enemyOverlayText" text="Lacerazione Spaziale" styleClass="card-title" wrapText="true"/>
        </StackPane>
    </VBox>

    <VBox fx:id="pauseMenuOverlay" visible="false" alignment="CENTER" styleClass="pause-overlay-bg">
        <VBox alignment="CENTER" spacing="20" maxWidth="350" styleClass="ps2-panel, menu-box">
            <Label text="SISTEMA IN PAUSA" styleClass="title-text, pause-title"/>
            <Button text="[ RIPRENDI ]" onAction="#onResumeClicked" styleClass="ps2-button" maxWidth="Infinity"/>
            <Button text="[ CARICA PARTITA ]" onAction="#onLoadInCombatClicked" styleClass="system-button" maxWidth="Infinity"/>
            <Button text="[ SALVA ED ESCI ]" onAction="#onSaveAndQuitClicked" styleClass="system-button" maxWidth="Infinity"/>
            <Button text="[ SALVA PARTITA ]" onAction="#onSaveClicked" styleClass="system-button" maxWidth="Infinity"/>
            <Button text="[ RIAVVIA SCONTRO ]" onAction="#onRestartClicked" styleClass="system-button" maxWidth="Infinity"/>
            <Button text="[ TORNA AL MENU' (SENZA SALVARE) ]" onAction="#onBackToMenuClicked" styleClass="system-button" maxWidth="Infinity"/>
        </VBox>
    </VBox>

</StackPane>
